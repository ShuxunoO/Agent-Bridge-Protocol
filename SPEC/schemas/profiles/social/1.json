{
  "abp_profile": "abp.social",
  "version": "1",
  "title": "Embodied social world",
  "description": "The official ABP World Profile for 2D embodied social simulations (AI-Town and similar). Defines the closed event/action vocabulary; the Core (SPEC/abp-v1.md) carries it. Fields marked x-abp-trust:untrusted carry foreign-authored text and MUST be treated as data, never instructions. Fields marked x-abp-trust:client_authored are subject to egress DLP. Each kind's `data` is a self-contained closed JSON Schema (refs inlined so it validates standalone).",
  "events": {
    "perception": {
      "description": "Environment snapshot for the bound role.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["self", "nearby"],
        "properties": {
          "self": {
            "type": "object",
            "additionalProperties": false,
            "required": ["position", "status"],
            "properties": {
              "position": {
                "type": "object",
                "additionalProperties": false,
                "required": ["x", "y"],
                "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
              },
              "status": { "type": "string", "maxLength": 64 }
            }
          },
          "nearby": {
            "type": "array",
            "maxItems": 256,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role", "distance"],
              "properties": {
                "role": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id"],
                  "properties": {
                    "id": { "type": "string", "maxLength": 128 },
                    "display_name": { "type": "string", "maxLength": 128, "x-abp-trust": "untrusted" }
                  }
                },
                "distance": { "type": "number", "minimum": 0 }
              }
            }
          },
          "world": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "context": {
                "type": "object",
                "x-abp-trust": "untrusted",
                "description": "Host-defined free context. The single open object in this profile (§5.4): UNTRUSTED data only, never instructions. Bounded for safety.",
                "maxProperties": 64,
                "additionalProperties": {
                  "anyOf": [
                    { "type": "string", "maxLength": 1024 },
                    { "type": "number" },
                    { "type": "boolean" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "message": {
      "description": "An utterance from another role.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_role", "conversation_id", "content", "seq"],
        "properties": {
          "from_role": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "maxLength": 128 },
              "display_name": { "type": "string", "maxLength": 128, "x-abp-trust": "untrusted" }
            }
          },
          "conversation_id": { "type": "string", "maxLength": 128 },
          "content": { "type": "string", "maxLength": 8192, "x-abp-trust": "untrusted" },
          "seq": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "invite": {
      "description": "An interaction invite from another role.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_role", "conversation_id"],
        "properties": {
          "from_role": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "maxLength": 128 },
              "display_name": { "type": "string", "maxLength": 128, "x-abp-trust": "untrusted" }
            }
          },
          "conversation_id": { "type": "string", "maxLength": 128 }
        }
      }
    },
    "turn": {
      "description": "Action opportunity. deadline_ms is RELATIVE to the client's local receipt (§4.3.3).",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["deadline_ms", "allowed_actions"],
        "properties": {
          "conversation_id": { "type": "string", "maxLength": 128 },
          "deadline_ms": { "type": "integer", "minimum": 0 },
          "allowed_actions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["say", "move", "interact_start", "interact_leave", "emote", "noop"]
            },
            "uniqueItems": true
          }
        }
      }
    },
    "tick": {
      "description": "World heartbeat / time passage.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["world_time"],
        "properties": { "world_time": { "type": "integer", "minimum": 0 } }
      }
    },
    "role_update": {
      "description": "The bound role's own state changed.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["patch"],
        "properties": {
          "patch": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "position": {
                "type": "object",
                "additionalProperties": false,
                "required": ["x", "y"],
                "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
              },
              "status": { "type": "string", "maxLength": 64 }
            }
          }
        }
      }
    }
  },
  "actions": {
    "say": {
      "description": "Utterance. text is client-authored; run egress DLP first.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conversation_id", "text"],
        "properties": {
          "conversation_id": { "type": "string", "maxLength": 128 },
          "text": { "type": "string", "minLength": 1, "maxLength": 8192, "x-abp-trust": "client_authored" },
          "redacted": { "type": "boolean" }
        }
      }
    },
    "move": {
      "description": "Navigate to a coordinate or toward a role.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["to"],
        "properties": {
          "to": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["x", "y"],
                "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["target_role"],
                "properties": { "target_role": { "type": "string", "maxLength": 128 } }
              }
            ]
          }
        }
      }
    },
    "interact_start": {
      "description": "Start a conversation/interaction. The host assigns and returns the conversation_id (§5.6.1).",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_role"],
        "properties": { "target_role": { "type": "string", "maxLength": 128 } }
      }
    },
    "interact_leave": {
      "description": "Leave a conversation.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conversation_id"],
        "properties": { "conversation_id": { "type": "string", "maxLength": 128 } }
      }
    },
    "emote": {
      "description": "Expression/gesture from a host-defined set.",
      "data": {
        "type": "object",
        "additionalProperties": false,
        "required": ["emote"],
        "properties": {
          "emote": { "type": "string", "maxLength": 64, "x-abp-trust": "client_authored" },
          "redacted": { "type": "boolean" }
        }
      }
    },
    "noop": {
      "description": "Explicitly do nothing this turn.",
      "data": { "type": "object", "additionalProperties": false }
    }
  }
}
