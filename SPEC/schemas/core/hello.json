{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bridge.dev/schemas/abp-v1/core/hello.json",
  "title": "ABP v1 hello payload (Client -> Host)",
  "description": "Open the connection: declare Core version, supported World Profiles, desired transport bindings, and optional client identity (§1, §4.1).",
  "type": "object",
  "additionalProperties": false,
  "required": ["abp_core", "profiles", "bindings"],
  "properties": {
    "abp_core": { "type": "string", "minLength": 1, "maxLength": 32 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "version": { "type": "string", "minLength": 1, "maxLength": 32 }
        }
      }
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["wss", "sse+https"] }
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 128 },
        "version": { "type": "string", "maxLength": 32 }
      }
    }
  }
}
