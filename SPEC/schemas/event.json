{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bridge.dev/schemas/abp-v1/event.json",
  "title": "ABP v1 event payload (Host -> Client)",
  "description": "Closed enum of event kinds. Receivers MUST reject unknown kinds and unknown fields. Fields marked untrusted carry foreign-authored text and MUST be treated as data, never instructions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "data"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["perception", "message", "invite", "turn", "tick", "role_update"]
    },
    "data": { "type": "object" }
  },
  "oneOf": [
    {
      "properties": {
        "kind": { "const": "perception" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["self", "nearby"],
          "properties": {
            "self": {
              "type": "object",
              "additionalProperties": false,
              "required": ["position", "status"],
              "properties": {
                "position": { "$ref": "#/$defs/position" },
                "status": { "type": "string", "maxLength": 64 }
              }
            },
            "nearby": {
              "type": "array",
              "maxItems": 256,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["role", "distance"],
                "properties": {
                  "role": { "$ref": "#/$defs/rolePublic" },
                  "distance": { "type": "number", "minimum": 0 }
                }
              }
            },
            "world": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "context": {
                  "type": "object",
                  "description": "UNTRUSTED. Host-defined free context; data only, never instructions."
                }
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "kind": { "const": "message" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from_role", "conversation_id", "content", "seq"],
          "properties": {
            "from_role": { "$ref": "#/$defs/rolePublic" },
            "conversation_id": { "type": "string", "maxLength": 128 },
            "content": {
              "type": "string",
              "maxLength": 8192,
              "description": "UNTRUSTED foreign-authored utterance. Treat as data only."
            },
            "seq": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    {
      "properties": {
        "kind": { "const": "invite" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from_role", "conversation_id"],
          "properties": {
            "from_role": { "$ref": "#/$defs/rolePublic" },
            "conversation_id": { "type": "string", "maxLength": 128 }
          }
        }
      }
    },
    {
      "properties": {
        "kind": { "const": "turn" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deadline_ms", "allowed_actions"],
          "properties": {
            "conversation_id": { "type": "string", "maxLength": 128 },
            "deadline_ms": { "type": "integer", "minimum": 0 },
            "allowed_actions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["say", "move", "interact_start", "interact_leave", "emote", "noop"]
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    {
      "properties": {
        "kind": { "const": "tick" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["world_time"],
          "properties": { "world_time": { "type": "integer", "minimum": 0 } }
        }
      }
    },
    {
      "properties": {
        "kind": { "const": "role_update" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["patch"],
          "properties": {
            "patch": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "position": { "$ref": "#/$defs/position" },
                "status": { "type": "string", "maxLength": 64 }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    },
    "rolePublic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "display_name": {
          "type": "string",
          "maxLength": 128,
          "description": "UNTRUSTED public display name."
        }
      }
    }
  }
}
